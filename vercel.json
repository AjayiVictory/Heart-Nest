{
  "buildCommand": "echo 'Frontend static files'",
  "outputDirectory": "frontend",
  "public": true,
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache, no-store, must-revalidate"
        }
      ]
    }
  ],
  "env": {
    "API_BASE_URL": "@api_base_url"
  }
}
